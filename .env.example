# Database — PostgreSQL (required)
# Start locally with: docker compose -f docker/docker-compose.local.yml up -d
# Production: use strong credentials and append ?sslmode=require
DATABASE_URL=postgresql://anima:anima@localhost:5432/anima

# Storage
# Leave empty for local filesystem storage
# Set to S3-compatible URL for cloud storage
STORAGE_ENDPOINT=
STORAGE_BUCKET=anima-ai
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# Cache + Queues — Valkey (Redis-compatible)
# Leave empty for in-memory cache
# Set to redis://:password@host:6379 for Valkey/Redis
# Local dev password: anima_valkey_dev (set in docker-compose.local.yml)
REDIS_URL=

# LLM Providers — configure at least one
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Docling Service
DOCLING_URL=http://localhost:8000

# Auth
AUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000

# Encryption (64-char hex string for AES-256-GCM, used to encrypt stored API keys)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave empty in dev — falls back to AUTH_SECRET
ENCRYPTION_KEY=

# Chat API
CHAT_API_URL=http://localhost:3001
CHAT_API_PORT=3001
# CORS origin allowed by the chat-api (Hono cors middleware)
# Set to your web app's URL in production (e.g. https://your-domain.com)
# Defaults to * (all origins) if not set — restrict this in production
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60
