    "@anima-ai/storage": "workspace:*",
    "@anima-ai/ai": "workspace:*",
    "@anima-ai/shared": "workspace:*",
    "hono": "^4.6.14",
    "@hono/node-server": "^1.13.7"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
