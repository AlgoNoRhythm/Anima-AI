{
  "name": "@anima-ai/chat-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env --env-file-if-exists=../../.env.local src/index.ts",
    "start": "tsx --env-file-if-exists=../../.env --env-file-if-exists=../../.env.local src/index.ts",
