{
  "name": "@anima-ai/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env --env-file-if-exists=../../.env.local src/index.ts",
    "start": "tsx --env-file-if-exists=../../.env --env-file-if-exists=../../.env.local src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anima-ai/ai": "workspace:*",
    "@anima-ai/cache": "workspace:*",
    "@anima-ai/database": "workspace:*",
    "@anima-ai/shared": "workspace:*",
    "@anima-ai/storage": "workspace:*",
    "drizzle-orm": "^0.36.4",
    "bullmq": "^5.31.0",
    "ioredis": "^5.4.2",
    "jszip": "^3.10.1",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@types/jszip": "^3.4.1",
    "@types/pdf-parse": "^1.1.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
